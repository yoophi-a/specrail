{
  "name": "@specrail/github",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "node --watch --import tsx src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node --import tsx src/index.ts",
    "start:built": "node --conditions=specrail-built dist/index.js"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.6"
  },
  "dependencies": {
    "pg": "^8.21.0"
  }
}
