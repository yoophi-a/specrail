    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@specrail/config": "workspace:*",
    "@specrail/core": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.20.6"
  }
}
